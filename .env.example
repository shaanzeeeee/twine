# ==============================
# Twine — Persona Intelligence Engine
# ==============================

# --- Database ---
DATABASE_URL=postgresql://user:password@localhost:5432/twine

# --- Groq (LLM Provider) ---
GROQ_API_KEY=gsk_your_groq_api_key_here
LLM_CHAT_MODEL=llama-3.3-70b-versatile
LLM_SAFETY_MODEL=llama-3.1-8b-instant

# --- OpenAI (for ChromaDB embeddings) ---
OPENAI_API_KEY=sk-your_openai_key_here
CHROMA_OPENAI_API_KEY=sk-your_openai_key_here

# --- Persona Configuration ---
PERSONA_NAME=Your Persona Name
PERSONA_DESCRIPTION=Describe your persona's identity, role, expertise, and background.
PERSONA_INSTRUCTIONS=Additional behavioral guidelines and communication style preferences.

# --- Security ---
SECRET_KEY=change-this-to-a-random-secret-in-production

# --- Google Drive Sync (optional) ---
DRIVE_FOLDER_ID=your_drive_folder_id
CREDENTIALS_FILE=credentials.json
TOKEN_FILE=token.json

# --- ChromaDB ---
CHROMA_DB_DIR=./chroma_data

# --- CORS ---
FRONTEND_URL=http://localhost:5173
